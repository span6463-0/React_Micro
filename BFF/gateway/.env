# BFF Environment Variables
NODE_ENV=development
BFF_PORT=4000

# CORS
CORS_ORIGINS=http://localhost:3000

# Service URLs
AUTH_API_URL=http://localhost:5001
USER_API_URL=http://localhost:5002
ITEM_API_URL=http://localhost:5003

# JWT Configuration
JWT_SECRET=local-dev-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Internal API Key (for service-to-service communication)
INTERNAL_API_KEY=internal-api-key-change-in-production
